{
  "expo": {
    "name": "LaporKita",
    "slug": "laporkita-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "laporkita",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#EFE5C8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.laporkita.mobile",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Untuk upload foto bukti laporan",
        "NSCameraUsageDescription": "Untuk mengambil foto bukti laporan"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EFE5C8"
      },
      "package": "com.laporkita.mobile",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Untuk upload foto bukti laporan",
          "cameraPermission": "Untuk mengambil foto bukti laporan"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0df1ef49-06e9-4a97-a02d-3675a5696416"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0df1ef49-06e9-4a97-a02d-3675a5696416"
    }
  }
}
